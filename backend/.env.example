# Server Configuration
PORT=<3000 or your preferred port>
HOST=<127.0.0.1 or your preferred host>
NODE_ENV=<development or production>

# JWT Configuration
JWT_EXPIRES_IN=<7d>
JWT_SECRET=<your-secret-key>

# Frontend URL
FRONTEND_URL=<http://localhost:5173 or your frontend URL>

# Seed User Configuration
SEED_PASSWORD=<default password for seeded users>

# Azure DB Configuration
AZURE_DB_HOST=<Azure database host>
AZURE_DB_PORT=<Azure database port>
AZURE_DB_NAME=<Azure database name>
AZURE_DB_USER=<Azure database user>
AZURE_DB_PASSWORD=<Azure database password>